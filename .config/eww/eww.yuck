(defpoll power_profile
  :interval "500ms"
"~/.config/eww/scripts/power-profile.sh get")

(defpoll current_clock
  :interval "1s"
"date '+%H:%M'")

(defpoll current_date
  :interval "60s"
"date '+%a, %d %b %Y'")

(defpoll user_fullname
  :interval "30s"
"~/.config/eww/scripts/user-info.sh fullname")

(defpoll system_hostname
  :interval "60s"
"~/.config/eww/scripts/user-info.sh hostname")

(defpoll current_time
  :interval "1s"
"date '+%H:%M - %a, %d %b %Y'")

(defpoll volume_value
  :interval "1s"
"wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2 * 100}'")

(defpoll volume_muted
  :interval "1s"
"wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED && echo yes || echo no")

(defpoll brightness_value
  :interval "1s"
"~/.config/eww/scripts/brightness.sh get")

(defpoll wifi_status
  :interval "2s"
"nmcli radio wifi")

(defpoll wifi_ssid
  :interval "2s"
"nmcli -t -f active,ssid dev wifi | grep '^yes' | cut -d: -f2")

(defpoll wifi_ip
  :interval "5s"
  "ip -4 addr show $(nmcli device | grep wifi | awk '{print $1}') | grep -oP '(?<=inet\\s)\\d+(\\.\\d+){3}' || echo 'Disconnected'")

(defpoll bluetooth_status
  :interval "2s"
"~/.config/eww/scripts/bluetooth.sh status")

(defpoll bluetooth_name
  :interval "2s"
"~/.config/eww/scripts/bluetooth.sh name")

(defpoll bluetooth_mac
  :interval "2s"
"~/.config/eww/scripts/bluetooth.sh mac")

(defpoll bluetooth_connected
  :interval "2s"
"~/.config/eww/scripts/bluetooth.sh connected")

(defpoll root_storage
  :interval "30s"
"df -BG / --output=used,size | tail -n1 | awk '{print $1\" / \"$2}'")


(defwindow dashboard
  :monitor 0
  :stacking "fg"
  :windowtype "dialog"
  :wm-ignore false
  :focusable true   ;; Tambahkan ini agar menangkap input
  :geometry (geometry
    :x "0px"
    :y "0px"
    :width "100%"
  :height "100%")
  (overlay
    (eventbox
      :hexpand true
      :vexpand true
    :onclick "eww close dashboard")
    (box
      :class "dashboard-container"
      :halign "center"
      :valign "center"
      (dashboard_layout)
    )
  )
)


(defwidget dashboard_slider [class icon onclick value onchange]
  (box
    :class "slider-box ${class}"
    :orientation "h"
    :space-evenly false
    (button
      :class "slider-icon-btn"
      :onclick onclick
      (label
        :class "slider-icon"
        :text icon
      )
    )
    (scale
      :class "slider-bar"
      :value value
      :min 0
      :max 101
      :orientation "h"
      :hexpand true
      :round-digits 0
      :onchange onchange
    )
  )
)


(defwidget qs_button [label icon onclick class]
  (button
    :class "qs-btn ${class}"
    :onclick onclick
    (box
      :orientation "h"
      :spacing 12
      :space-evenly false
      (label :class "qs-icon" :text icon)
      (label :class "qs-label" :text label)
    )
  )
)


(defwidget quick_settings []
  (box
    :class "qs-container"
    :orientation "v"
    :spacing 8
    
    (box
      :orientation "h"
      :spacing 8
      :homogeneous true
      
      (overlay
        (button
          :class "qs-side-label wifi overlay-label"
          :hexpand true
          :onclick "~/.config/eww/scripts/nmtui.sh & eww close dashboard"
          (box
            :orientation "v"
            :halign "start"
            (label
              :class "qs-label-main"
              :halign "start"
              :limit-width 12
              :text {wifi_status == "enabled" && wifi_ssid != "" ? wifi_ssid : "WiFi Off"}
            )
            (label
              :class "qs-label-sub"
              :halign "start"
              :text {wifi_status == "enabled" ? wifi_ip : "Disconnected"}
            )
          )
        )
        
        (button
          :class "qs-side-icon wifi overlay-icon ${wifi_ssid != '' ? 'active' : ''}"
          :halign "start"
          :valign "center"
          :onclick "~/.config/eww/scripts/wifi.sh toggle" ;; Panggil script wrapper
          (label
            :style "margin-right: 6px;"
            :text {wifi_status == "enabled" ? "󰤨" : "󰤭"}
          )
        )
      )
      
      (qs_button
        :label root_storage
        :icon "󰋊"
        :class "disk"
        :onclick "kitty btop & eww close dashboard"
      )
    )
    
    (box
      :orientation "h"
      :spacing 8
      :homogeneous true
      
      (overlay
        (button
          :class "qs-side-label blue overlay-label"
          :hexpand true
          :onclick "kitty bluetui & eww close dashboard"
          (box
            :orientation "v"
            :halign "start"
            (label
              :class "qs-label-main"
              :halign "start"
              :limit-width 12
              :text {
              bluetooth_name != ""
              ? bluetooth_name
              : bluetooth_status == "enabled"
              ? "Bluetooth"
              : "Bluetooth Off"
              }
            )
            (label
              :class "qs-label-sub"
              :halign "start"
              :text {
              bluetooth_name != ""
              ? bluetooth_mac
              : "Disconnected"
              }
            )
          )
        )
        
        (button
          :class "qs-side-icon blue overlay-icon ${bluetooth_connected == 'yes' ? 'active' : ''}"
          :halign "start"
          :valign "center"
          :onclick "~/.config/eww/scripts/bluetooth.sh toggle"
          (label
            :text {
            bluetooth_connected == "yes"
            ? "󰂱"
            : bluetooth_status == "enabled"
            ? "󰂯"
            : "󰂲"
            }
          )
        )
      )
      
      (qs_button
        :label "Picker"
        :icon "󰈋"
        :class "color"
        :onclick "~/.config/eww/scripts/picker.sh &"
      )
    )
  )
)


(defwidget system_actions []
  (box
    :class "system-actions"
    :orientation "h"
    :spacing 8
    :homogeneous true
    
    (button :class "sys-btn" :onclick "~/.config/eww/scripts/power-menu.sh lock"     (label :text "󰌾"))
    (button :class "sys-btn" :onclick "~/.config/eww/scripts/power-menu.sh logout"    (label :text "󰗽"))
    (button :class "sys-btn" :onclick "~/.config/eww/scripts/power-menu.sh suspend"   (label :text "󰤄"))
    (button :class "sys-btn" :onclick "~/.config/eww/scripts/power-menu.sh reboot"    (label :text "󰑓"))
    (button :class "sys-btn danger" :onclick "~/.config/eww/scripts/power-menu.sh shutdown" (label :text ""))
  )
)


(defwidget dashboard_layout []
  (box
    :class "dashboard-window"
    :orientation "v"
    :space-evenly false
    
    (overlay
      (box
        :class "cover-image"
        :hexpand true
      )
      
      (box
        :class "cover-time-text"
        :orientation "v"
        :spacing 0
        
        (label
          :class "cover-clock"
          :text current_clock
        )
        
        (label
          :class "cover-date"
          :text current_date
        )
      )
    )
    
    (box
      :class "header-row"
      :orientation "h"
      :space-evenly false
      
      (box :class "profile-pic")
      
      (box :hexpand true)
      
      (box
        :class "power-box"
        :orientation "h"
        :spacing 5
        
        (button
          :class "power-btn psave ${power_profile == 'powersave' ? 'active' : ''}"
          :onclick "~/.config/eww/scripts/power-profile.sh set powersave"
          (label :text "󰾆")
        )
        (button
          :class "power-btn bal ${power_profile == 'balanced' ? 'active' : ''}"
          :onclick "~/.config/eww/scripts/power-profile.sh set balanced"
          (label :text "󰾅")
        )
        (button
          :class "power-btn perf ${power_profile == 'performance' ? 'active' : ''}"
          :onclick "~/.config/eww/scripts/power-profile.sh set throughput-performance"
          (label :text "󰓅")
        )
      )
    )
    
    (box
      :class "user-box"
      :orientation "v"
      :halign "start"
      (label :class "user-name" :text user_fullname)
      (label :class "user-host" :halign "start" :text {"@" + system_hostname})
    )
    
    (box
      :class "slider-group"
      :orientation "v"
      
      (dashboard_slider
        :class "vol-slider"
        :icon {volume_muted == "yes" ? "󰖁" : "󰕾"}
        :onclick "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
        :value volume_value
        :onchange "wpctl set-volume @DEFAULT_AUDIO_SINK@ {}%"
      )
      
      (dashboard_slider
        :class "br-slider"
        :icon "󰃠"
        :onclick "niri msg action power-off-monitors"
        :value brightness_value
        :onchange "~/.config/eww/scripts/brightness.sh set {}"
      )
    )
    
    (quick_settings)
    (system_actions)
  )
)