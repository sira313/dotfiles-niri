#!/usr/bin/fish

# Definisi opsi dengan ikon
set options "ůįóĹ Logout\nůįĎď Reboot\nÔÄĎ Shutdown\nůį§Ą Suspend\nůįĆĺ Lock"

# Memanggil fuzzel dalam mode dmenu
set choice (printf $options | fuzzel --dmenu --prompt="Power: " --lines=5 --width=20)

# Logika pemilihan menggunakan switch (syntax fish)
switch $choice
    case "*Logout"
        niri msg action quit --skip-confirmation
    case "*Reboot"
        systemctl reboot
    case "*Shutdown"
        systemctl poweroff
    case "*Suspend"
        systemctl suspend
    case "*Lock"
        if command -v hyprlock >/dev/null
            hyprlock
        else if command -v swaylock >/dev/null
            swaylock
        else
            notify-send "Error" "No screen locker found"
        end
end